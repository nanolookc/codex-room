{
  "name": "codex-room",
  "private": true,
  "packageManager": "bun@1.2.22",
  "bin": {
    "codex-room": "./cli/src/index.ts"
  },
  "workspaces": [
    "backend",
    "cli",
    "frontend",
    "relay",
    "shared"
  ],
  "scripts": {
    "dev": "bun run --cwd backend dev & bun run --cwd frontend dev",
    "dev:backend": "bun run --cwd backend dev",
    "dev:frontend": "bun run --cwd frontend dev",
    "dev:relay": "bun run --cwd relay dev",
    "start:anywhere": "bun run ./cli/src/index.ts start",
    "build": "bun run --cwd shared build && bun run --cwd backend build && bun run --cwd relay build && bun run --cwd frontend build",
    "test": "bun test --runInBand",
    "test:frontend": "bun test frontend/src --runInBand"
  }
}
